{
  "name": "insulin-shot-tracker",
  "version": "1.0.0",
  "license": "SEE LICENSE IN LICENSE",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-picker/picker": "2.11.1",
    "expo": "~54.0.0",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-haptics": "~15.0.8",
    "expo-localization": "~17.0.9",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "i18next": "^26.3.6",
    "react": "19.1.0",
    "react-i18next": "^17.0.9",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/jest": "~29.5.14",
    "@types/react": "~19.1.0",
    "@types/uuid": "^10.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.0",
    "ts-jest": "^29.4.11",
    "typescript": "~5.6.0"
  },
  "scripts": {
    "start": "expo start",
    "dev:ios": "expo run:ios",
    "dev:android": "expo run:android",
    "prebuild:ios": "expo prebuild -p ios",
    "prebuild:android": "expo prebuild -p android",
    "debug:ios": "npm run prebuild:ios && npm run dev:ios -- --device",
    "debug:android": "npm run prebuild:android && npm run dev:android -- --device",
    "device:ios": "npm run debug:ios -- --configuration Release",
    "device:android": "npm run debug:android -- --configuration Release",
    "web": "expo start --web",
    "test": "jest",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx"
    ]
  },
  "private": true
}